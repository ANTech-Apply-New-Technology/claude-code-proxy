# === Claude Code Proxy — Multi-Provider ===
# Copy to .env and fill in values: cp .env.example .env

PREFERRED_PROVIDER=anthropic

# --- Gemini OAuth (Google One AI Pro subscription) ---
USE_GEMINI_OAUTH=true
# Extract from Gemini CLI source (public, embedded in binary)
GEMINI_CLI_CLIENT_ID=
GEMINI_CLI_CLIENT_SECRET=
GEMINI_PROJECT_ID=

# --- Codex CLI (ChatGPT Plus subscription) ---
USE_CODEX_CLI=true
CODEX_MODEL=

# --- Model mapping ---
BIG_MODEL=gemini-2.5-pro
SMALL_MODEL=gemini-2.5-flash

# --- API Keys (optional) ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
